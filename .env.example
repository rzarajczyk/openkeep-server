# Copy this file to .env, then replace every CHANGE_ME value before starting.
# Generate secrets with: openssl rand -base64 32

OPENKEEP_PORT=8080

POSTGRES_DB=openkeep
POSTGRES_USER=openkeep
POSTGRES_PASSWORD=CHANGE_ME_use_a_unique_random_database_password

# Keep the JSON on one line. Single quotes preserve JSON and any literal '$'
# characters in passwords from Compose interpolation.
OPENKEEP_USERS_JSON='[{"login":"admin","password":"CHANGE_ME_use_a_long_unique_admin_password"},{"login":"member","password":"CHANGE_ME_use_a_different_long_unique_password"}]'

# ISO-8601 duration understood by Spring (for example PT12H or P7D).
OPENKEEP_TOKEN_TTL=PT24H

# Byte values: 25 MiB per file, 26 MiB including multipart overhead, and
# 1 GiB total per user. Keep the request size larger than the file size.
OPENKEEP_ATTACHMENT_MAX_FILE_SIZE=26214400
OPENKEEP_MULTIPART_MAX_REQUEST_SIZE=27262976
OPENKEEP_ATTACHMENT_PER_USER_QUOTA=1073741824

# Development only. Leave empty in Compose, where the web service proxies /api.
# For a separately-run Vite dev server, use its exact origin.
OPENKEEP_CORS_ALLOWED_ORIGINS=
